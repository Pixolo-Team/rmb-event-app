# ── Database ────────────────────────────────────────────────────────────────
# LOCAL (Docker, `docker compose up -d postgres`): point both URLs at localhost.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evento?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/evento?schema=public"

# SUPABASE: from Dashboard → Project Settings → Database → Connection string.
#  - DATABASE_URL = "Transaction" pooler URI (port 6543) + pgbouncer params:
#      postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
#  - DIRECT_URL   = "Session" pooler / direct URI (port 5432), used only by `prisma migrate`:
#      postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Email (magic-link login) ────────────────────────────────────────────────
# SMTP_USER/SMTP_PASS unset → dev mode: the link is logged and shown on-screen
# instead of emailed. Set → real sends over SMTP (defaults are Gmail; use a
# Google "app password", not the account password). Swapping providers later is
# just an env change — the code is provider-agnostic.
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_USER="you@gmail.com"
# SMTP_PASS="<16-char app password>"
# MAIL_FROM="Evento <you@gmail.com>"

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
WEB_ORIGIN="http://localhost:3000"
SESSION_JWT_SECRET="change-me-to-a-long-random-string"
NODE_ENV=development
