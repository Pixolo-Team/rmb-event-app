generator client {
  provider = "prisma-client-js"
}

// DATABASE_URL: runtime connection. On Supabase use the transaction pooler
// (port 6543, `?pgbouncer=true&connection_limit=1`). DIRECT_URL: direct
// connection (port 5432) used only by `prisma migrate`. For local Docker
// Postgres, point both at the same localhost URL.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ImportRowStatus {
  OK
  DUPLICATE
  ERROR
  FLAGGED
}

model Chapter {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  attendees Attendee[]
}

model Attendee {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String   @unique
  createdAt DateTime @default(now())

  businessName String?
  chapter      Chapter? @relation(fields: [chapterId], references: [id])
  chapterId    String?
  photoUrl     String?

  // Profile — filled in during onboarding (Screen 1.1), empty until then.
  // city/businessCategory may also arrive pre-filled from the import file.
  // businessCategory is the only categorization field — no separate industry column.
  businessCategory   String?
  city               String?
  lookingFor         String[] @default([])
  offering           String[] @default([])
  goals              String[] @default([])
  bio                String?
  profileCompletedAt DateTime?

  // Signed, opaque, non-sequential — generated at import time (PRD Security & Privacy).
  qrToken String @unique

  magicLinkTokens MagicLinkToken[]
  onboardingTokens OnboardingToken[]
  bookmarksMade   Bookmark[] @relation("BookmarksMade")
  bookmarksOnMe   Bookmark[] @relation("BookmarksOnMe")
  photos          Photo[]
  likes           Like[]
  comments        Comment[]
}

model Bookmark {
  attendee   Attendee @relation("BookmarksMade", fields: [attendeeId], references: [id])
  attendeeId String
  target     Attendee @relation("BookmarksOnMe", fields: [targetId], references: [id])
  targetId   String
  createdAt  DateTime @default(now())

  @@id([attendeeId, targetId])
  @@index([attendeeId, createdAt])
  @@index([targetId])
}

model MagicLinkToken {
  id         String    @id @default(uuid())
  attendee   Attendee  @relation(fields: [attendeeId], references: [id])
  attendeeId String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([attendeeId, createdAt])
}

// Longer-lived than a login link (72h per PRD) and reusable until the profile is
// completed — an attendee may reopen the WhatsApp invite more than once.
model OnboardingToken {
  id         String   @id @default(uuid())
  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  attendeeId String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([attendeeId])
}

model ImportBatch {
  id             String     @id @default(uuid())
  fileName       String
  successCount   Int        @default(0)
  duplicateCount Int        @default(0)
  errorCount     Int        @default(0)
  flaggedCount   Int        @default(0)
  createdAt      DateTime   @default(now())
  rows           ImportRow[]
}

model ImportRow {
  importBatch   ImportBatch     @relation(fields: [importBatchId], references: [id])
  importBatchId String
  id            String          @id @default(uuid())
  rowNumber     Int
  rawData       Json
  status        ImportRowStatus
  reason        String?

  @@index([importBatchId])
}

model Photo {
  id         String   @id @default(uuid())
  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  attendeeId String
  // Relative path served by the API's static route, e.g. "/uploads/photos/<uuid>.jpg" —
  // stored relative so the frontend resolves it through the same-origin Next.js
  // rewrite regardless of environment.
  url        String
  caption    String?
  createdAt  DateTime @default(now())

  likes    Like[]
  comments Comment[]

  @@index([attendeeId])
  @@index([createdAt])
}

model Like {
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId    String
  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  attendeeId String
  createdAt  DateTime @default(now())

  @@id([photoId, attendeeId])
  @@index([attendeeId])
}

model Comment {
  id         String   @id @default(uuid())
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photoId    String
  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  attendeeId String
  message    String
  createdAt  DateTime @default(now())

  @@index([photoId, createdAt])
}

// Standalone audit snapshot for admin feed moderation's "deleted-post history log".
// Photo rows are hard-deleted on admin delete (disappears exactly like a self-delete,
// no placeholder state), so this is a snapshot table, not a soft-delete flag on Photo.
model DeletedPhotoLog {
  id           String   @id @default(uuid())
  photoId      String // original Photo.id — no FK, row no longer exists
  attendeeId   String // original poster's id — no FK, same reason
  attendeeName String // denormalized snapshot at delete time
  caption      String?
  photoUrl     String
  postedAt     DateTime
  deletedAt    DateTime @default(now())
  // No admin identity captured yet — admin auth (PF3) isn't built anywhere in this app.
  deletedBy    String   @default("admin")

  @@index([deletedAt])
}
