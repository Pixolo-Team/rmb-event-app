{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "api", "start:dev"],
      "port": 4000
    },
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "web", "dev"],
      "port": 3000
    },
    {
      "name": "api-alt",
      "runtimeExecutable": "env",
      "runtimeArgs": ["PORT=4010", "pnpm", "--filter", "api", "start:dev"],
      "port": 4010
    },
    {
      "name": "web-alt",
      "runtimeExecutable": "env",
      "runtimeArgs": ["PORT=3010", "API_ORIGIN=http://localhost:4000", "pnpm", "--filter", "web", "dev"],
      "port": 3010
    }
  ]
}
